.tab-bar{position:fixed;bottom:0;left:0;right:0;display:flex;background:#fff;border-top:1px solid rgba(0,0,0,.04);padding:4px 0 8px;z-index:100}.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px}.tab-icon{width:24px;height:24px}.tab-label{font-size:10px;color:#999}.tab-item.active .tab-label{color:#4e9e80}
