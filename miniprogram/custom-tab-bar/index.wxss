.tab-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; background: #fff;
  border-top: 1px solid rgba(0,0,0,.04);
  padding: 4px 0 calc(8px + env(safe-area-inset-bottom));
  z-index: 100;
}

.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; gap: 1px; padding: 4px 0;
}

.tab-icon {
  font-size: 22px; line-height: 1;
}

.tab-label {
  font-size: 10px; color: #999;
}

.tab-item.active .tab-label {
  color: #4e9e80; font-weight: 600;
}

.tab-item.active .tab-icon {
  color: #4e9e80;
}

/* 发布按钮 */
.pub-btn {
  width: 36px; height: 36px; border-radius: 50%;
  background: #4e9e80; display: flex;
  align-items: center; justify-content: center;
  margin-top: -8px;
  box-shadow: 0 2px 6px rgba(78,158,128,.3);
}

.pub-icon {
  font-size: 22px; color: #fff; font-weight: 300;
  line-height: 1;
}

.pub-label {
  color: #4e9e80; font-weight: 600;
}
