<view class="page">
  <!-- 出售/出租切换 -->
  <view class="type-bar">
    <view class="type-btn {{tradeType === 'sell' ? 'type-on' : ''}}" bindtap="switchType" data-type="sell">
      <view class="type-icon {{tradeType === 'sell' ? 'icon-on' : ''}}">✓</view>
      <text>出售</text>
    </view>
    <view class="type-btn {{tradeType === 'rent' ? 'type-on' : ''}}" bindtap="switchType" data-type="rent">
      <view class="type-icon {{tradeType === 'rent' ? 'icon-on' : ''}}">🏠</view>
      <text>出租</text>
    </view>
  </view>

  <!-- 商品图片 -->
  <view class="section">
    <view class="section-header">
      <text class="section-icon">📷</text>
      <text class="section-title">商品图片</text>
    </view>
    <view class="image-grid">
      <view class="image-box" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="image-preview" />
        <view class="image-del" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="image-add" wx:if="{{images.length < 6}}" bindtap="addImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加照片</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-header">
      <text class="section-icon">📋</text>
      <text class="section-title">基本信息</text>
    </view>

    <view class="field">
      <text class="field-label">物品名称 *</text>
      <input class="field-input" placeholder="请输入物品名称" value="{{title}}" bindinput="onInput" data-field="title" />
    </view>
    <view class="field">
      <text class="field-label">物品描述</text>
      <textarea class="field-textarea" placeholder="描述物品的新旧、使用情况..." value="{{desc}}" bindinput="onInput" data-field="desc" />
    </view>
    <view class="field">
      <text class="field-label">分类 *</text>
      <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
        <view class="field-picker">
          <text class="{{category ? 'pv-val' : 'pv-ph'}}">{{category || '选择分类'}}</text>
          <text class="pv-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="field">
      <text class="field-label">成色</text>
      <picker mode="selector" range="{{qualities}}" bindchange="onQualityChange">
        <view class="field-picker">
          <text class="{{quality ? 'pv-val' : 'pv-ph'}}">{{quality || '选择成色'}}</text>
          <text class="pv-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 价格 -->
  <view class="section">
    <view class="section-header">
      <text class="section-icon">¥</text>
      <text class="section-title">价格</text>
    </view>

    <view class="field" wx:if="{{tradeType === 'sell'}}">
      <text class="field-label">售价（元）</text>
      <input class="field-input" placeholder="请输入售价" value="{{price}}" bindinput="onInput" data-field="price" type="digit" />
    </view>

    <view class="field" wx:if="{{tradeType === 'rent'}}">
      <text class="field-label">租价（元/月）</text>
      <input class="field-input" placeholder="请输入月租价" value="{{rentPrice}}" bindinput="onInput" data-field="rentPrice" type="digit" />
    </view>
    <view class="field" wx:if="{{tradeType === 'rent'}}">
      <text class="field-label">押金（元）</text>
      <input class="field-input" placeholder="请输入押金" value="{{deposit}}" bindinput="onInput" data-field="deposit" type="digit" />
    </view>
    <view class="field" wx:if="{{tradeType === 'rent'}}">
      <text class="field-label">租期</text>
      <picker mode="selector" range="{{rentPeriods}}" bindchange="onRentPeriodChange">
        <view class="field-picker">
          <text class="{{rentPeriod ? 'pv-val' : 'pv-ph'}}">{{rentPeriod || '选择租期'}}</text>
          <text class="pv-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="field">
      <view class="checkbox-row">
        <view class="checkbox {{negotiable ? 'cb-on' : ''}}" bindtap="toggleNegotiable">
          <text wx:if="{{negotiable}}">✓</text>
        </view>
        <text class="checkbox-label">可议价</text>
      </view>
    </view>
  </view>

  <!-- 交易偏好 -->
  <view class="section">
    <view class="section-header">
      <text class="section-icon">👤</text>
      <text class="section-title">交易偏好</text>
    </view>
    <view class="field">
      <text class="field-label">期望交易对象</text>
      <view class="gender-pref-bar">
        <view class="gp-item {{genderPref === '' ? 'gp-on' : ''}}" bindtap="setGenderPref" data-val="">不限</view>
        <view class="gp-item {{genderPref === 'male' ? 'gp-on' : ''}}" bindtap="setGenderPref" data-val="male">仅男</view>
        <view class="gp-item {{genderPref === 'female' ? 'gp-on' : ''}}" bindtap="setGenderPref" data-val="female">仅女</view>
      </view>
    </view>
  </view>

  <!-- 提交 -->
  <button class="submit-btn" bindtap="submitProduct">{{isEdit ? '保存修改' : '发布商品'}}</button>
</view>
