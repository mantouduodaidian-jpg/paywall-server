.page {
  padding: 0 16px 40px;
  background: #f8f5f0;
  min-height: 100vh;
}

/* 出售/出租切换 */
.type-bar {
  display: flex;
  gap: 8px;
  padding: 12px 0;
}

.type-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px;
  border-radius: 10px;
  background: #f0eee8;
  font-size: 15px;
  font-weight: 500;
  color: rgba(0,0,0,.3);
}

.type-on {
  background: rgba(78,158,128,.08);
  color: #4a8c6d;
  font-weight: 600;
}

.type-icon {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(0,0,0,.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
}

.icon-on {
  background: #4a8c6d;
  color: #fff;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 14px;
}

.section-icon {
  font-size: 16px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

/* 图片 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.image-box {
  width: 80px;
  height: 80px;
  border-radius: 10px;
  overflow: hidden;
  position: relative;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-del {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(0,0,0,.5);
  color: #fff;
  font-size: 14px;
  text-align: center;
  line-height: 20px;
}

.image-add {
  width: 80px;
  height: 80px;
  border-radius: 10px;
  border: 1.5px dashed rgba(0,0,0,.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 24px;
  color: rgba(0,0,0,.12);
}

.add-text {
  font-size: 11px;
  color: rgba(0,0,0,.15);
  margin-top: 4px;
}

/* 字段 */
.field {
  margin-bottom: 14px;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 13px;
  color: rgba(0,0,0,.45);
  margin-bottom: 4px;
  display: block;
}

.field-input {
  width: 100%;
  height: 42px;
  padding: 0 12px;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,.06);
  background: #f5f2eb;
  font-size: 14px;
  color: #333;
  box-sizing: border-box;
}

.field-input::placeholder {
  color: rgba(0,0,0,.2);
}

.field-textarea {
  width: 100%;
  min-height: 80px;
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,.06);
  background: #f5f2eb;
  font-size: 14px;
  color: #333;
  box-sizing: border-box;
}

.field-textarea::placeholder {
  color: rgba(0,0,0,.2);
}

.field-picker {
  display: flex;
  align-items: center;
  height: 42px;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,.06);
  background: #f5f2eb;
  padding: 0 12px;
}

.pv-val {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.pv-ph {
  flex: 1;
  font-size: 14px;
  color: rgba(0,0,0,.2);
}

.pv-arrow {
  font-size: 16px;
  color: rgba(0,0,0,.12);
}

/* 复选框 */
.checkbox-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.checkbox {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  border: 1.5px solid rgba(0,0,0,.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: rgba(0,0,0,.15);
}

.cb-on {
  background: #4a8c6d;
  border-color: #4a8c6d;
  color: #fff;
}

.checkbox-label {
  font-size: 14px;
  color: rgba(0,0,0,.35);
}

/* 性别偏好 */
.gender-pref-bar {
  display: flex;
  gap: 8px;
}

.gp-item {
  flex: 1;
  padding: 10px;
  border-radius: 8px;
  background: #f5f2eb;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  color: rgba(0,0,0,.25);
}

.gp-on {
  background: rgba(78,158,128,.08);
  color: #4a8c6d;
  border: 1px solid rgba(78,158,128,.2);
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  padding: 14px;
  border-radius: 12px;
  background: linear-gradient(135deg, #4a8c6d, #3d7a5e);
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  text-align: center;
  border: none;
  margin-top: 12px;
}
