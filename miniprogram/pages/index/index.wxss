.page {
  background: #f7f3ea;
  min-height: 100vh;
  padding-bottom: 80px;
}

.user-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px 8px;
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,.04);
}

.ub-left { display: flex; align-items: center; gap: 10px; }

.ub-avatar {
  width: 34px; height: 34px; border-radius: 50%;
  flex-shrink: 0;
}

.ub-name-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.ub-name { font-size: 17px; font-weight: 700; color: #333; }

.ub-beta {
  display: flex; align-items: center; gap: 2px;
  padding: 2px 8px; border-radius: 4px;
  background: rgba(78,158,128,.1);
  font-size: 11px; color: #4a8c6d; font-weight: 600;
}

.ub-arrow { font-size: 7px; }

.ub-login {
  padding: 5px 16px; border-radius: 6px;
  background: rgba(78,158,128,.1); color: #4a8c6d;
  font-size: 13px; font-weight: 600;
  flex-shrink: 0;
}

.ub-logged {
  padding: 5px 12px; border-radius: 6px;
  background: rgba(78,158,128,.08); color: #4a8c6d;
  font-size: 13px;
  flex-shrink: 0;
}

.cat-bar {
  display: flex; white-space: nowrap;
  padding: 10px 16px; background: #f7f3ea;
}

.cat-item {
  display: inline-flex; padding: 5px 14px; margin-right: 10px;
  border-radius: 12px; font-size: 13px;
  color: rgba(0,0,0,.45); background: #f0ece2;
  font-weight: 500;
  flex-shrink: 0;
}

.cat-item.active {
  color: #fff;
  background: linear-gradient(135deg,#4e9e80,#3d8a6e);
  font-weight: 600;
}

.search-bar {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 16px;
  background: #f7f3ea;
}

.search-wrap {
  flex: 1; display: flex; align-items: center;
  height: 34px; border-radius: 17px;
  background: #fff; padding: 0 12px;
  border: 1px solid rgba(0,0,0,.04);
}

.search-input {
  flex: 1; font-size: 14px; color: #333; height: 100%;
  background: transparent;
}

.search-input::placeholder { color: rgba(0,0,0,.2); }

.search-btn {
  padding: 6px 14px; border-radius: 6px;
  background: #4a8c6d; color: #fff;
  font-size: 13px; font-weight: 500;
  border: none; line-height: 1.4;
  flex-shrink: 0;
}

.type-bar {
  display: flex; gap: 6px;
  padding: 8px 16px;
  background: #f7f3ea;
}

.type-btn {
  flex: 1; display: flex; align-items: center;
  justify-content: center;
  padding: 10px; border-radius: 6px;
  background: #e8e4da;
  font-size: 14px; font-weight: 500; color: rgba(0,0,0,.3);
}

.type-active {
  background: rgba(78,158,128,.12);
  color: #4a8c6d; font-weight: 600;
}

.filter-bar {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 16px;
  background: #f7f3ea;
}

.filter-sort {
  padding: 5px 10px; border-radius: 5px;
  background: #e8e4da; font-size: 12px;
  color: rgba(0,0,0,.45); flex-shrink: 0;
}

.filter-sort-on {
  background: rgba(78,158,128,.08); color: #4a8c6d;
  font-weight: 500;
}

.filter-price {
  display: flex; align-items: center; gap: 4px; flex: 1;
}

.fp-input {
  flex: 1; padding: 5px 8px; border-radius: 5px;
  background: #fff; font-size: 12px; color: #555;
  width: 50px; min-width: 0; height: 28px;
  border: 1px solid rgba(0,0,0,.04);
}

.fp-sep { font-size: 12px; color: rgba(0,0,0,.15); }

.filter-btn {
  padding: 5px 14px; border-radius: 5px;
  background: #4a8c6d; color: #fff;
  font-size: 12px; font-weight: 600;
  border: none; line-height: 1.8; flex-shrink: 0;
}

.stats-bar { padding: 4px 16px; background: #f7f3ea; }
.stats-text { font-size: 11px; color: rgba(0,0,0,.25); }

.product-list { padding: 0 12px; }

.product-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
}

.product-card {
  background: #fff; border-radius: 6px; overflow: hidden;
  border: 1px solid rgba(0,0,0,.04);
}

.pc-img {
  width: 100%; aspect-ratio: 1;
  background: rgba(0,0,0,.03);
  display: flex; align-items: center; justify-content: center;
  position: relative;
}

.pc-img image { width: 100%; height: 100%; }
.pc-img-placeholder { font-size: 32px; color: rgba(0,0,0,.06); }

.pc-badge {
  position: absolute; top: 6px; right: 6px;
  font-size: 10px; font-weight: 600;
  padding: 2px 8px; border-radius: 4px;
}

.pc-sold { background: #ef4444; color: #fff; }
.pc-pending { background: rgba(251,191,36,.12); color: #d97706; }

.pc-photos {
  position: absolute; bottom: 6px; right: 6px;
  background: rgba(0,0,0,.5); color: #fff;
  font-size: 9px; padding: 2px 6px; border-radius: 4px;
}

.pc-info { padding: 8px 10px; }

.pc-title {
  font-size: 13px; color: #555;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  display: block;
}

.pc-price {
  font-size: 16px; font-weight: 700; color: #4a8c6d;
  margin: 4px 0; display: block;
}

.pc-unit { font-size: 11px; font-weight: 400; color: rgba(78,158,128,.6); }

.pc-meta { display: flex; gap: 4px; flex-wrap: wrap; }

.pc-tag {
  padding: 2px 6px; border-radius: 3px;
  background: rgba(0,0,0,.04);
  font-size: 10px; color: rgba(0,0,0,.3);
}

.empty-state {
  display: flex; align-items: center; justify-content: center;
  padding: 80px 0;
}

.empty-text { font-size: 16px; color: rgba(0,0,0,.15); }

.load-more {
  text-align: center; padding: 20px;
  font-size: 12px; color: rgba(0,0,0,.2);
}
