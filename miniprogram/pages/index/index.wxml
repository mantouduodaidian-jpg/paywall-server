<view class="page">
  <!-- ── Top Bar ── -->
  <view class="top-bar">
    <image class="logo" src="/images/logo.jpg" mode="aspectFit" />
    <view class="school-selector {{user ? 'fixed' : ''}}" bindtap="toggleSchool">
      <text class="school-name">{{schoolName}}</text>
      <text class="arrow {{showSchool ? 'up' : 'down'}}">▼</text>
    </view>
    <view class="user-area">
      <block wx:if="{{user}}">
        <image class="top-avatar" src="{{user.avatar || '/images/tab-me.png'}}" bindtap="goProfile" mode="aspectFill" />
      </block>
      <block wx:else>
        <button class="login-btn" bindtap="goLogin">登录</button>
      </block>
    </view>
  </view>

  <!-- ── School Dropdown (visitor only) ── -->
  <view class="school-mask {{showSchool ? 'show' : ''}}" bindtap="toggleSchool"></view>
  <view class="school-dropdown {{showSchool ? 'show' : ''}}">
    <view class="school-item {{schoolCode === '' ? 'active' : ''}}" bindtap="pickSchool" data-code="">
      <text>全部学校</text>
      <text class="check" wx:if="{{schoolCode === ''}}">✓</text>
    </view>
    <view wx:for="{{schools}}" wx:key="code" class="school-item {{schoolCode === item.code ? 'active' : ''}}" bindtap="pickSchool" data-code="{{item.code}}">
      <text>{{item.name}}</text>
      <text class="check" wx:if="{{schoolCode === item.code}}">✓</text>
    </view>
  </view>

  <!-- ── Announcement Bar ── -->
  <view class="ann-bar {{annShow ? '' : 'hidden'}}" bindtap="goAnnouncement">
    <text class="ann-icon">📢</text>
    <view class="ann-scroll">
      <text class="ann-text">{{annText}}</text>
    </view>
    <text class="ann-go">›</text>
  </view>

  <!-- ── Category Bar ── -->
  <scroll-view class="cat-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="cat-item {{selCat === '' ? 'active' : ''}}" bindtap="setCat" data-cat="">
      <text>全部</text>
    </view>
    <view class="cat-item {{selCat === '__my__' ? 'active' : ''}}" bindtap="setCat" data-cat="my">
      <text>我的</text>
    </view>
    <view class="cat-item {{selCat === '__fav__' ? 'active' : ''}}" bindtap="setCat" data-cat="fav">
      <text>收藏</text>
    </view>
    <view wx:for="{{cats}}" wx:key="id" class="cat-item {{selCat === (item.code || item.id) ? 'active' : ''}}" bindtap="setCat" data-cat="{{item.code || item.id}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- ── Search Bar ── -->
  <view class="search-bar">
    <view class="search-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品名称..." value="{{search}}" bindconfirm="onSearch" confirm-type="search" />
      <text class="search-clear {{search ? 'show' : ''}}" bindtap="clearSearch">✕</text>
    </view>
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- ── Sort / Filter Row ── -->
  <view class="filter-row">
    <picker class="sort-picker" range="{{sortOpts}}" value="{{sortIdx}}" bindchange="onSort">
      <view class="sort-display">
        <text class="sort-label">{{sortOpts[sortIdx]}}</text>
        <text class="sort-arrow">▾</text>
      </view>
    </picker>

    <view class="type-tabs">
      <view class="type-tab {{itemType === 'sell' ? 'active' : ''}}" bindtap="toggleItemType" data-type="sell">
        <text>🛒 出售</text>
      </view>
      <view class="type-tab {{itemType === 'buy' ? 'active' : ''}}" bindtap="toggleItemType" data-type="buy">
        <text>📋 求购</text>
      </view>
      <view class="type-tab {{itemType === 'rent' ? 'active' : ''}}" bindtap="toggleItemType" data-type="rent">
        <text>📦 租赁</text>
      </view>
    </view>

    <view class="filter-btn" bindtap="toggleFilter">
      <text>筛选 ▾</text>
    </view>
  </view>

  <!-- ── Filter Popup ── -->
  <view class="filter-mask {{showFilter ? 'show' : ''}}" bindtap="toggleFilter"></view>
  <view class="filter-panel {{showFilter ? 'show' : ''}}">
    <view class="filter-header">
      <text class="filter-title">价格区间</text>
      <text class="filter-close" bindtap="toggleFilter">✕</text>
    </view>
    <view class="price-row">
      <input class="price-input" placeholder="最低价" value="{{priceMin}}" bindinput="onPriceMin" type="digit" />
      <text class="price-sep">—</text>
      <input class="price-input" placeholder="最高价" value="{{priceMax}}" bindinput="onPriceMax" type="digit" />
    </view>
    <button class="filter-apply" bindtap="applyFilter">确定筛选</button>
  </view>

  <!-- ── Product Grid ── -->
  <view class="product-grid" wx:if="{{list.length > 0}}">
    <view wx:for="{{list}}" wx:key="id" class="product-card" bindtap="goDetail" data-id="{{item.id}}">
      <image class="card-img" src="{{item.images && item.images[0] || item.image || ''}}" mode="aspectFill" />
      <view class="card-info">
        <text class="card-title">{{item.title}}</text>
        <view class="card-price-row">
          <text wx:if="{{item.item_type === 'rent' && item.rent_price}}" class="card-price">¥{{item.rent_price}}<text class="card-unit">/天</text></text>
          <text wx:else class="card-price">¥{{item.price}}</text>
          <text wx:if="{{item.quality}}" class="card-quality">{{item.quality}}</text>
        </view>
        <view class="card-meta">
          <text class="card-school" wx:if="{{item.schoolName}}">{{item.schoolName}}</text>
          <text class="card-time">{{(item.created_at || '').substring(0, 10)}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ── Load More ── -->
  <view class="load-more" wx:if="{{list.length > 0}}">
    <text wx:if="{{hasMore}}" class="loading-text">上拉加载更多</text>
    <text wx:else class="end-text">— 已经到底了 —</text>
  </view>

  <!-- ── Empty State ── -->
  <view class="empty-state" wx:if="{{list.length === 0 && resultLabel !== '加载中...'}}">
    <image class="empty-img" src="/images/tab-home.png" mode="aspectFit" />
    <text class="empty-text">{{resultLabel}}</text>
    <view class="empty-actions">
      <button class="empty-btn" bindtap="onPullDownRefresh">刷新试试</button>
    </view>
  </view>

  <!-- ── Initial Loading ── -->
  <view class="init-loading" wx:if="{{list.length === 0 && resultLabel === '加载中...'}}">
    <text class="init-text">加载中...</text>
  </view>
</view>
