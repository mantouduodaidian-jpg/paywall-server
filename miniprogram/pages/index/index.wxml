<view class="page">
  <!-- 顶部用户栏 -->
  <view class="user-bar">
    <view class="ub-left">
      <image class="ub-avatar" src="/images/logo.jpg" mode="aspectFill" />
      <view class="ub-info">
        <view class="ub-name-row">
          <text class="ub-name">二豆校园</text>
          <view class="ub-beta" bindtap="onBetaTap">
            <text>内测服</text>
            <text class="ub-arrow">▼</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{!user}}" class="ub-login" bindtap="onLoginTap">登录</view>
    <text wx:else class="ub-logged" bindtap="onLoginTap">{{user.nickname || user.name || '已登录'}}</text>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="cat-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="cat-item {{selCat === '' ? 'active' : ''}}" bindtap="setCat" data-cat="">
      <text>全部</text>
    </view>
    <view class="cat-item {{selCat === '__my__' ? 'active' : ''}}" bindtap="setCat" data-cat="my">
      <text>我的</text>
    </view>
    <view class="cat-item {{selCat === '__fav__' ? 'active' : ''}}" bindtap="setCat" data-cat="fav">
      <text>收藏</text>
    </view>
    <view wx:for="{{cats}}" wx:key="id" class="cat-item {{selCat === (item.code || item.id) ? 'active' : ''}}" bindtap="setCat" data-cat="{{item.code || item.id}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-wrap">
      <input class="search-input" placeholder="搜索商品..." value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 出售/出租切换 -->
  <view class="type-bar">
    <view class="type-btn {{tradeType === 'sell' ? 'type-active' : ''}}" bindtap="onTypeTap" data-type="sell">
      <text>出售</text>
    </view>
    <view class="type-btn {{tradeType === 'rent' ? 'type-active' : ''}}" bindtap="onTypeTap" data-type="rent">
      <text>出租</text>
    </view>
  </view>

  <!-- 排序/筛选 -->
  <view class="filter-bar">
    <view class="filter-sort {{sortBy === 'latest' ? 'filter-sort-on' : ''}}" bindtap="onSortTap">
      <text>{{sortBy === 'latest' ? '最新' : '最新'}}</text>
    </view>
    <view class="filter-price">
      <input class="fp-input" placeholder="¥ 最低" value="{{minPrice}}" bindinput="onMinPriceInput" type="digit" />
      <text class="fp-sep">-</text>
      <input class="fp-input" placeholder="¥ 最高" value="{{maxPrice}}" bindinput="onMaxPriceInput" type="digit" />
    </view>
    <button class="filter-btn" bindtap="onFilterConfirm">确定</button>
  </view>

  <!-- 统计行 -->
  <view class="stats-bar">
    <text class="stats-text">{{activeCatLabel || '全部'}} · {{totalCount}} 件 · 第{{page + 1}}/{{totalPages}}页</text>
  </view>

  <!-- 商品列表 -->
  <view class="product-list" wx:if="{{products.length > 0}}">
    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="pc-img">
          <image wx:if="{{item.images && item.images.length > 0}}" src="{{'https://paywall-server.onrender.com' + item.images[0]}}" mode="aspectFill" />
          <text wx:else class="pc-img-placeholder">📦</text>
          <view wx:if="{{item.status === 'sold'}}" class="pc-badge pc-sold">已售</view>
          <view wx:elif="{{item.status === 'pending'}}" class="pc-badge pc-pending">待审</view>
          <view wx:if="{{item.images && item.images.length > 1}}" class="pc-photos">{{item.images.length}}</view>
        </view>
        <view class="pc-info">
          <text class="pc-title">{{item.title}}</text>
          <text class="pc-price">{{item.trade_type === 'rent' ? (item.rent_price || item.price) : item.price}}<text class="pc-unit">{{item.trade_type === 'rent' ? '/月' : '元'}}</text></text>
          <view class="pc-meta">
            <text class="pc-tag">{{item.school || '未知'}}</text>
            <text class="pc-tag" wx:if="{{item.quality}}">{{item.quality}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 空状态：纯文字无图标 -->
  <view class="empty-state" wx:else>
    <text class="empty-text">还没有商品</text>
  </view>
</view>
