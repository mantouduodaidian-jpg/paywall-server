.page{display:flex;flex-direction:column;height:100vh;background:#f7f3ea}.chat-back{display:flex;align-items:center;padding:40px 12px 8px;background:#fff;border-bottom:1px solid rgba(0,0,0,.04);flex-shrink:0;z-index:10}.back-hit{display:inline-flex;align-items:center;gap:2px;cursor:pointer;padding:2px 0}.back-hit:active{background:rgba(0,0,0,.04);border-radius:4px}.back-arrow{font-size:22px;color:#4e9e80;font-weight:300;line-height:1}.back-text{font-size:14px;color:#4e9e80}.chat-title{font-size:15px;font-weight:600;color:#333;flex:1;text-align:center;padding-right:40px}.ch-spacer{width:40px;flex-shrink:0}.trade-picker{display:flex;align-items:center;padding:0 12px;background:rgba(78,158,128,.04);border-bottom:1px solid rgba(78,158,128,.08);flex-shrink:0;min-height:40px}.tp-val{font-size:12px;color:#4e9e80;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 8px;height:40px;line-height:40px}.tp-arrow{font-size:12px;color:rgba(78,158,128,.3)}.product-header{display:flex;align-items:center;gap:8px;padding:10px 12px;background:#fff;border-bottom:1px solid rgba(0,0,0,.04);flex-shrink:0}.ph-icon{font-size:24px;flex-shrink:0}.ph-info{flex:1;overflow:hidden}.ph-title{font-size:13px;font-weight:600;color:#333;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.ph-price{font-size:11px;color:#4e9e80;margin-top:2px}.ph-arrow{font-size:18px;color:rgba(0,0,0,.15)}.trade-bar{flex-shrink:0;padding:8px 12px;background:rgba(78,158,128,.06);border-bottom:1px solid rgba(78,158,128,.08)}.trade-actions{display:flex;flex-direction:column;gap:6px}.trade-info{padding:4px 0}.trade-tip{font-size:12px;color:#4e9e80;text-align:center}.trade-btns{display:flex;gap:6px}.trade-btn{flex:1;padding:8px;border-radius:8px;font-size:12px;font-weight:600;text-align:center;border:none}.trade-btn.confirm{background:#4e9e80;color:#fff}.trade-btn.cancel{background:rgba(0,0,0,.05);color:rgba(0,0,0,.4)}.msgs{flex:1;height:0;padding:12px;overflow-y:auto}.msg{margin-bottom:12px;width:100%}.mine{text-align:right}.other{text-align:left}.bubble{display:inline-block;padding:8px 14px;border-radius:14px;max-width:80%;font-size:14px;line-height:1.5;word-break:break-word}.mine .bubble{background:rgba(78,158,128,.12);color:#2d7a62;border-radius:14px 14px 4px 14px}.other .bubble{background:#fff;color:rgba(0,0,0,.8);border-radius:14px 14px 14px 4px}.time{font-size:10px;color:rgba(0,0,0,.35);margin-top:2px}.img-preview{display:flex;align-items:center;gap:6px;padding:6px 12px;background:#f7f3ea;border-top:1px solid rgba(0,0,0,.04);flex-shrink:0}.img-preview-src{width:48px;height:48px;border-radius:6px;object-fit:cover}.img-preview-del{font-size:14px;color:rgba(0,0,0,.2);padding:4px}.input-row{display:flex;gap:6px;padding:10px 12px;background:#fff;border-top:1px solid rgba(0,0,0,.04);flex-shrink:0}.ipt{flex:1;padding:8px 12px;border-radius:8px;border:1px solid rgba(0,0,0,.06);background:#f7f3ea;font-size:14px}.img-btn{width:36px;height:36px;border-radius:8px;background:rgba(0,0,0,.03);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}.send{padding:8px 20px;border-radius:8px;background:#4e9e80;color:#fff;font-size:13px;font-weight:600;border:none}.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.3);z-index:99}.review-modal{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:16px 16px 0 0;z-index:100;padding:16px;max-height:70vh;overflow-y:auto}.rev-title{font-size:16px;font-weight:700;color:#333;text-align:center;margin-bottom:12px}.rev-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}.rev-tag{padding:6px 12px;border-radius:6px;font-size:12px;background:#f5f2eb;color:rgba(0,0,0,.3)}.rev-tag.active{background:rgba(78,158,128,.08);color:#4e9e80}.rev-text{width:100%;min-height:60px;padding:10px;border-radius:8px;border:1px solid rgba(0,0,0,.06);font-size:13px;box-sizing:border-box;margin-bottom:10px}.rev-imgs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}.rev-img{width:56px;height:56px;border-radius:6px;overflow:hidden;position:relative}.rev-img-src{width:100%;height:100%}.rev-img-del{position:absolute;top:-2px;right:-2px;font-size:12px;color:rgba(0,0,0,.3);background:#fff;border-radius:50%;width:18px;height:18px;text-align:center;line-height:18px}.rev-img-add{width:56px;height:56px;border-radius:6px;border:1.5px dashed rgba(0,0,0,.1);display:flex;align-items:center;justify-content:center;font-size:24px;color:rgba(0,0,0,.12)}.rev-btns{display:flex;gap:8px}.rev-btn{flex:1;padding:10px;border-radius:8px;font-size:14px;font-weight:600;text-align:center}.rev-btn.cancel{background:rgba(0,0,0,.04);color:rgba(0,0,0,.35)}.rev-btn.primary{background:rgba(78,158,128,.1);color:#4e9e80}
