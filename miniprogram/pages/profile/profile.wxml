<view class="page">
  <view class="profile-header">
    <image class="avatar" src="/images/logo.jpg" mode="aspectFill" />
    <view class="info">
      <text class="name">{{user.name||'未登录'}}</text>
      <text class="school" wx:if="{{schoolName}}">{{schoolName}}</text>
      <text class="school none" wx:else>未设置学校</text>
    </view>
    <view class="logout" bindtap="doLogout" wx:if="{{user}}">退出</view>
  </view>
  <view class="credit-card" wx:if="{{user}}">
    <text class="cc-label">信用分</text>
    <text class="cc-score">{{creditScore}}</text>
  </view>
  <view class="menu">
    <view class="item" wx:if="{{user && !schoolName}}" bindtap="showSchoolPicker">🏫 选择学校</view>
    <view class="item" bindtap="goMyProducts">📦 我的商品</view>
    <view class="item" bindtap="goMyPurchases">🛒 我的购买</view>
    <view class="item" bindtap="goMyFavs">❤️ 我的收藏</view>
    <view class="item">🔔 声音提醒<switch class="sw" color="#4e9e80" checked="{{soundOn}}" bindchange="toggleSound" /></view>
  </view>
  <view class="menu" wx:if="{{!user}}">
    <view class="item center" bindtap="goLogin">登录/注册</view>
  </view>
  <view class="modal-overlay" wx:if="{{showPicker}}" bindtap="hideSchoolPicker"></view>
  <view class="modal" wx:if="{{showPicker}}">
    <view class="modal-title">选择学校</view>
    <view wx:for="{{schools}}" wx:key="code" class="modal-item" bindtap="pickSchool" data-code="{{item.code}}">{{item.name}}</view>
  </view>
</view>
