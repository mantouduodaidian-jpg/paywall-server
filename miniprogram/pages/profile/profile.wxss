.page{padding-bottom:24px;background:#f7f3ea;min-height:100vh}.profile-header{display:flex;align-items:center;gap:14px;padding:44px 16px 16px;background:linear-gradient(135deg,#4e9e80,#3d8a6e);color:#fff}.avatar{width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:600;flex-shrink:0}.info{flex:1}.name{font-size:16px;font-weight:600;display:block}.school{font-size:12px;opacity:.7;margin-top:2px;display:block}.school.none{opacity:.4}.logout{font-size:12px;opacity:.7;padding:6px 12px;border-radius:6px;border:1px solid rgba(255,255,255,.3)}.credit-card{display:flex;align-items:center;justify-content:space-between;margin:12px 16px;padding:14px 16px;background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.04)}.cc-label{font-size:13px;color:rgba(0,0,0,.45)}.cc-score{font-size:24px;font-weight:700;color:#4e9e80}.menu{background:#fff;border-radius:14px;margin:0 16px 12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04)}.item{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;font-size:14px;color:#555;border-bottom:1px solid rgba(0,0,0,.04)}.item:last-child{border-bottom:none}.item:active{background:rgba(78,158,128,.04)}.item.center{justify-content:center;color:#4e9e80;font-weight:600}.sw{transform:scale(.7);transform-origin:right center}.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.3);z-index:99}.modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#fff;border-radius:16px;padding:20px;width:280px;z-index:100;box-shadow:0 8px 30px rgba(0,0,0,.1)}.modal-title{font-size:16px;font-weight:700;color:#333;text-align:center;margin-bottom:14px}.modal-item{padding:12px 14px;border-radius:8px;font-size:14px;color:#555;text-align:center}.modal-item:active{background:rgba(78,158,128,.06);color:#4e9e80}
