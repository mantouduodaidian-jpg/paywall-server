<view class="page">
  <!-- LOGO 区域 -->
  <view class="logo-area">
    <view class="logo-circle">
      <image src="/images/logo.jpg" mode="aspectFill" class="logo-img" />
    </view>
    <text class="logo-title">二豆</text>
    <text class="logo-sub">校园严选 · 二手集市</text>
  </view>

  <!-- 注册/登录切换 -->
  <view class="mode-bar">
    <view class="mode {{mode === 'register' ? 'mode-active' : ''}}" bindtap="switchMode" data-mode="register">注册</view>
    <view class="mode {{mode === 'login' ? 'mode-active' : ''}}" bindtap="switchMode" data-mode="login">登录</view>
  </view>

  <!-- 注册表单 -->
  <view class="form" wx:if="{{mode === 'register'}}">
    <view class="field">
      <text class="field-label">姓名 *</text>
      <input class="field-input" placeholder="请输入真实姓名" value="{{name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="field">
      <text class="field-label">学号 *</text>
      <input class="field-input" placeholder="请输入学号" value="{{studentId}}" bindinput="onInput" data-field="studentId" />
    </view>
    <view class="field">
      <text class="field-label">手机号 *</text>
      <input class="field-input" placeholder="请输入手机号" value="{{phone}}" bindinput="onInput" data-field="phone" type="number" maxlength="11" />
    </view>
    <view class="field">
      <text class="field-label">昵称</text>
      <input class="field-input" placeholder="给自己取个昵称" value="{{nickname}}" bindinput="onInput" data-field="nickname" />
    </view>
    <view class="field">
      <text class="field-label">学校 *</text>
      <picker mode="selector" range="{{schools}}" bindchange="onSchoolChange">
        <view class="field-picker">
          <text class="{{school ? 'picker-val' : 'picker-ph'}}">{{school || '请选择学校'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="field">
      <text class="field-label">性别</text>
      <view class="gender-bar">
        <view class="gender {{gender === 'male' ? 'gender-active' : ''}}" bindtap="setGender" data-gender="male">
          <text>男</text>
        </view>
        <view class="gender {{gender === 'female' ? 'gender-active' : ''}}" bindtap="setGender" data-gender="female">
          <text>女</text>
        </view>
      </view>
    </view>
    <view class="field">
      <text class="field-label">学生证照片</text>
      <view class="upload-row">
        <view class="upload-box" bindtap="uploadCard">
          <text class="upload-plus">+</text>
        </view>
        <image wx:if="{{cardImage}}" src="{{cardImage}}" class="upload-preview" mode="aspectFill" />
        <text class="upload-tip" wx:if="{{cardImage}}">{{cardImageName || '已上传'}}</text>
      </view>
    </view>
    <button class="btn" bindtap="doRegister">注册</button>
  </view>

  <!-- 登录表单 -->
  <view class="form" wx:else>
    <view class="field">
      <text class="field-label">学号</text>
      <input class="field-input" placeholder="请输入学号" value="{{studentId}}" bindinput="onInput" data-field="studentId" />
    </view>
    <view class="field">
      <text class="field-label">手机号</text>
      <input class="field-input" placeholder="请输入手机号" value="{{phone}}" bindinput="onInput" data-field="phone" type="number" maxlength="11" />
    </view>
    <button class="btn" bindtap="doLogin">登录</button>
    <text class="tip">首次使用请切换到"注册"</text>
  </view>

  <!-- 内测入口 -->
  <view class="beta-entrance" bindtap="enterBeta">
    <text class="beta-star">✨</text>
    <text class="beta-text">内测入口</text>
  </view>
</view>
