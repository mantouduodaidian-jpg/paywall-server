.page {
  padding: 0 24px 48px;
  background: #f8f5f0;
  min-height: 100vh;
}

/* LOGO */
.logo-area {
  padding-top: 40px;
  text-align: center;
  margin-bottom: 28px;
}

.logo-circle {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: #4a8c6d;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
}

.logo-img {
  width: 72px;
  height: 72px;
  border-radius: 50%;
}

.logo-text {
  font-size: 32px;
  color: #fff;
  font-weight: 700;
}

.logo-title {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: #4a8c6d;
  letter-spacing: 2px;
}

.logo-sub {
  display: block;
  font-size: 12px;
  color: rgba(0,0,0,.25);
  margin-top: 4px;
}

/* 模式切换 */
.mode-bar {
  display: flex;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(78,158,128,.15);
  margin-bottom: 20px;
}

.mode {
  flex: 1;
  padding: 10px;
  text-align: center;
  font-size: 14px;
  font-weight: 500;
  color: rgba(0,0,0,.25);
  background: #fff;
}

.mode-active {
  background: rgba(78,158,128,.08);
  color: #4a8c6d;
  font-weight: 600;
}

/* 表单 */
.form {
  background: #fff;
  border-radius: 14px;
  padding: 20px;
  box-shadow: 0 1px 4px rgba(0,0,0,.04);
}

.field {
  margin-bottom: 14px;
}

.field:last-of-type {
  margin-bottom: 0;
}

.field-label {
  font-size: 13px;
  color: rgba(0,0,0,.45);
  margin-bottom: 4px;
  display: block;
}

.field-input {
  width: 100%;
  height: 42px;
  padding: 0 12px;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,.06);
  background: #f5f2eb;
  font-size: 14px;
  color: #333;
  box-sizing: border-box;
}

.field-input::placeholder {
  color: rgba(0,0,0,.2);
}

.field-picker {
  display: flex;
  align-items: center;
  height: 42px;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,.06);
  background: #f5f2eb;
  padding: 0 12px;
}

.picker-val {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.picker-ph {
  flex: 1;
  font-size: 14px;
  color: rgba(0,0,0,.2);
}

.picker-arrow {
  font-size: 16px;
  color: rgba(0,0,0,.15);
}

/* 性别 */
.gender-bar {
  display: flex;
  gap: 8px;
}

.gender {
  flex: 1;
  padding: 9px;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,.06);
  background: #f5f2eb;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  color: rgba(0,0,0,.25);
}

.gender-active {
  background: rgba(78,158,128,.08);
  color: #4a8c6d;
  border-color: rgba(78,158,128,.2);
}

/* 上传 */
.upload-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.upload-box {
  width: 72px;
  height: 72px;
  border-radius: 12px;
  border: 1.5px dashed rgba(0,0,0,.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.upload-plus {
  font-size: 24px;
  color: rgba(0,0,0,.12);
}

.upload-preview {
  width: 72px;
  height: 72px;
  border-radius: 12px;
  flex-shrink: 0;
}

.upload-tip {
  font-size: 12px;
  color: rgba(0,0,0,.25);
}

/* 按钮 */
.btn {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  background: linear-gradient(135deg, #4a8c6d, #3d7a5e);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  border: none;
  margin-top: 16px;
  text-align: center;
}

.tip {
  display: block;
  text-align: center;
  font-size: 12px;
  color: rgba(0,0,0,.2);
  margin-top: 12px;
}

/* 内测入口 */
.beta-entrance {
  margin-top: 24px;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.beta-star {
  font-size: 14px;
}

.beta-text {
  font-size: 13px;
  color: rgba(0,0,0,.25);
}
