.page{padding:0 24px 48px;background:#f7f3ea;min-height:100vh}.logo-img{width:72px;height:72px;border-radius:50%;display:block;margin:0 auto 8px}.logo{text-align:center;font-size:28px;font-weight:700;color:#4e9e80;letter-spacing:2px;margin-top:32px}.subtitle{text-align:center;font-size:12px;color:rgba(0,0,0,.25);margin-top:4px;margin-bottom:28px}.mode-bar{display:flex;border-radius:10px;overflow:hidden;border:1px solid rgba(78,158,128,.15);margin-bottom:20px}.mode{flex:1;padding:8px;text-align:center;font-size:14px;font-weight:500;color:rgba(0,0,0,.25);background:#fff}.mode.active{background:rgba(78,158,128,.08);color:#4e9e80;font-weight:600}.form{background:#fff;border-radius:14px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,.04)}.field{margin-bottom:14px}.field:last-child{margin-bottom:0}.label{font-size:12px;color:rgba(0,0,0,.45);margin-bottom:4px;display:block}.ipt{width:100%;height:42px;padding:0 12px;border-radius:8px;border:1px solid rgba(0,0,0,.06);background:#f5f2eb;font-size:15px;color:#333;box-sizing:border-box}.ipt::placeholder{color:rgba(0,0,0,.2)}.btn{width:100%;padding:12px;border-radius:10px;background:linear-gradient(135deg,#4e9e80,#3d8a6e);color:#fff;font-size:15px;font-weight:600;border:none;margin-top:12px}.btn-beta{background:linear-gradient(135deg,#6c5ce7,#5a4bd1)}.tip{text-align:center;font-size:12px;color:rgba(0,0,0,.2);margin-top:12px}.beta-entrance{margin-top:16px;text-align:center}.beta-link{font-size:12px;color:rgba(0,0,0,.25)}.beta-badge{text-align:center;font-size:13px;color:#6c5ce7;font-weight:600;margin-bottom:12px}.beta-box{margin-top:10px;padding:12px;border-radius:10px;background:rgba(108,92,231,.04);border:1px solid rgba(108,92,231,.1)}.beta-hint{font-size:11px;color:rgba(0,0,0,.2);text-align:center;margin-top:8px}.field-row{display:flex;gap:10px}.field-row .half{flex:1}.gender-bar{display:flex;gap:6px}.gender{flex:1;padding:9px;border-radius:8px;border:1px solid rgba(0,0,0,.06);background:#f5f2eb;font-size:13px;font-weight:500;text-align:center;color:rgba(0,0,0,.25)}.gender.active{background:rgba(78,158,128,.08);color:#4e9e80;border-color:rgba(78,158,128,.2)}.picker-wrap{display:flex;align-items:center;height:42px;border-radius:8px;border:1px solid rgba(0,0,0,.06);background:#f5f2eb;padding:0 12px}.picker-val{font-size:15px;color:#333;flex:1}.picker-val.ph{color:rgba(0,0,0,.2)}.picker-arrow{font-size:12px;color:rgba(0,0,0,.12)}.upload-row{display:flex;align-items:center;gap:10px}.upload-box{width:72px;height:72px;border-radius:12px;border:1.5px dashed rgba(0,0,0,.1);display:flex;align-items:center;justify-content:center}.upload-plus{font-size:24px;color:rgba(0,0,0,.15)}.upload-preview{width:72px;height:72px;border-radius:12px}.upload-tip{font-size:12px;color:rgba(0,0,0,.25)}.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.3);z-index:99}.modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#fff;border-radius:16px;padding:20px;width:280px;z-index:100;box-shadow:0 8px 30px rgba(0,0,0,.1)}.modal-title{font-size:16px;font-weight:700;color:#333;text-align:center;margin-bottom:4px}.modal-sub{font-size:12px;color:rgba(0,0,0,.25);text-align:center;margin-bottom:14px}.modal-item{padding:12px 14px;border-radius:8px;font-size:14px;color:#555;text-align:center}.modal-item:active{background:rgba(78,158,128,.06);color:#4e9e80}
