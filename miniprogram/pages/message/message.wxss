/* ── Page Base ── */
.page {
  padding: 0 0 96px;
  background: #f7f3ea;
  min-height: 100vh;
}

/* ── Header ── */
.msg-header {
  display: flex;
  align-items: center;
  padding: 48px 16px 10px;
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,.04);
}
.msg-title {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  flex: 1;
}
.msg-spacer {
  width: 40px;
}

/* ── Login Prompt ── */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}
.prompt-img {
  width: 64px;
  height: 64px;
  opacity: .3;
  margin-bottom: 16px;
}
.prompt-text {
  font-size: 14px;
  color: rgba(0,0,0,.25);
  margin-bottom: 20px;
}
.prompt-btn {
  padding: 10px 32px;
  border-radius: 20px;
  background: linear-gradient(135deg, #4e9e80, #3d8a6e);
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  border: none;
}

/* ── Loading ── */
.msg-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
}
.msg-loading-text {
  font-size: 14px;
  color: rgba(0,0,0,.2);
}

/* ── Empty State ── */
.msg-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}
.empty-img {
  width: 64px;
  height: 64px;
  opacity: .3;
  margin-bottom: 16px;
}
.empty-text {
  font-size: 14px;
  color: rgba(0,0,0,.25);
}

/* ── Contact List ── */
.contact-list {
  padding: 0;
}
.contact-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,.03);
  transition: background .15s;
  cursor: pointer;
}
.contact-item:active {
  background: #faf8f4;
}
.contact-item:last-child {
  border-bottom: none;
}
.contact-avatar-wrap {
  position: relative;
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  margin-right: 12px;
}
.contact-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: block;
  background: #f0ede4;
  border: 2px solid rgba(78,158,128,.1);
}
.unread-badge {
  position: absolute;
  top: -3px;
  right: -3px;
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  background: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
  box-shadow: 0 1px 3px rgba(231,76,60,.3);
}
.unread-num {
  font-size: 10px;
  color: #fff;
  font-weight: 600;
}
.contact-info {
  flex: 1;
  min-width: 0;
}
.contact-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}
.contact-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}
.contact-time {
  font-size: 12px;
  color: rgba(0,0,0,.2);
  flex-shrink: 0;
  margin-left: 8px;
}
.contact-msg {
  display: block;
  font-size: 13px;
  color: rgba(0,0,0,.35);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
